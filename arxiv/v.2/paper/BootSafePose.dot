
digraph G {
  graph [
    pad="0.3",
    nodesep="0.35",
    ranksep="0.5",
    splines=true,
    bgcolor="white"
  ];
  node [
    shape=box,
    style="rounded,filled",
    color="#263238",
    fillcolor="#F7F3E8",
    fontname="Helvetica",
    fontsize=11,
    margin="0.12,0.08"
  ];
  edge [
    color="#455A64",
    fontname="Helvetica",
    fontsize=10,
    arrowsize=0.7
  ];

  rankdir=TB;

  Boot [label="Boot", fillcolor="#E8F1E7"];
  Pose [label="Boot /\nSafe Pose", fillcolor="#E8F1E7"];
  Listen [label="Resume\nListener", fillcolor="#E7EEF7"];
  Main [label="MainLoop\nReady State", fillcolor="#FBE9D0"];

  Boot -> Pose;
  Pose -> Listen;
  Listen -> Main [label="ready"];
}
